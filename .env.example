# =============================================================================
# Domu — Production Environment Variables
# Copy this file to .env and fill in the values before deploying.
# Used by docker-compose.prod.yml
# =============================================================================

# -----------------------------------------------------------------------------
# Security
# Must be a long, random string. Used for JWT signing (API) and
# JWT verification (Next.js frontend). Both services must share the same value.
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
SECRET_KEY=

# JWT algorithm (default: HS256, no need to change unless you know why)
# ALGORITHM=HS256

# -----------------------------------------------------------------------------
# Database
# Password for the postgres user. Used by both the API (DATABASE_URL) and
# the db service (POSTGRES_PASSWORD).
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# Hostnames (for reverse proxy / Let's Encrypt)
# API_HOST: public domain for the FastAPI service  (e.g. api.domu.ar)
# HOST:     public domain for the Next.js frontend (e.g. domu.ar)
# -----------------------------------------------------------------------------
API_HOST=api.domu.ar
HOST=domu.ar
